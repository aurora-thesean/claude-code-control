#!/usr/bin/env bash
# qmemmap-read-test — Unit 12 Memory Map Inspector Test Suite
#
# E2E test recipe:
# 1. Run: qmemmap-read $$
# 2. Verify JSON valid
# 3. Check memory_regions is array
# 4. Verify at least HEAP and STACK regions present
# 5. Check TEXT_SEGMENT has path to binary
# 6. Verify libc_location present (if system libc available)
# 7. Parse with jq

set -euo pipefail

PASSED=0
FAILED=0

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Test helper
assert_pass() {
    local test_name="$1"
    echo -e "${GREEN}✓${NC} $test_name"
    ((PASSED++))
}

assert_fail() {
    local test_name="$1"
    local reason="$2"
    echo -e "${RED}✗${NC} $test_name"
    echo "  Reason: $reason"
    ((FAILED++))
}

# Get script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Start a background sleep process and keep PID
bash -c 'sleep 300 &' & sleep 0.2
TEST_PID=$(pgrep -f "sleep 300" | head -1)

if [[ -z "$TEST_PID" ]]; then
    echo -e "${RED}CRITICAL${NC}: Could not start test process"
    exit 1
fi

echo "Testing with PID: $TEST_PID"
echo ""

# Run qmemmap-read and capture output
OUTPUT=$("$SCRIPT_DIR/qmemmap-read" "$TEST_PID" 2>&1)
EXIT_CODE=$?

# Test 1: Valid JSON
if echo "$OUTPUT" | python3 -m json.tool >/dev/null 2>&1; then
    assert_pass "JSON is valid"
else
    assert_fail "JSON is valid" "Output failed JSON validation"
    echo "Output: $OUTPUT"
    kill "$TEST_PID" 2>/dev/null || true
    exit 1
fi

# Test 2: Exit code is 0
if [[ $EXIT_CODE -eq 0 ]]; then
    assert_pass "Exit code is 0"
else
    assert_fail "Exit code is 0" "Got $EXIT_CODE"
fi

# Test 3: memory_regions is array
if echo "$OUTPUT" | jq -e '.data.memory_regions | type == "array"' >/dev/null 2>&1; then
    assert_pass "memory_regions is array"
else
    assert_fail "memory_regions is array" "Type is not array"
fi

# Test 4: At least one HEAP region
if echo "$OUTPUT" | jq -e '.data.memory_regions[] | select(.type == "HEAP")' >/dev/null 2>&1; then
    assert_pass "HEAP region present"
else
    assert_fail "HEAP region present" "No [heap] found"
fi

# Test 5: At least one STACK region
if echo "$OUTPUT" | jq -e '.data.memory_regions[] | select(.type == "STACK")' >/dev/null 2>&1; then
    assert_pass "STACK region present"
else
    assert_fail "STACK region present" "No [stack] found"
fi

# Test 6: At least one TEXT_SEGMENT with a binary path
if echo "$OUTPUT" | jq -e '.data.memory_regions[] | select(.type == "TEXT_SEGMENT" and .path != "" and .path != null)' >/dev/null 2>&1; then
    assert_pass "TEXT_SEGMENT has binary path"
else
    assert_fail "TEXT_SEGMENT has binary path" "No TEXT_SEGMENT with path found"
fi

# Test 7: libc_location is present and non-empty
if echo "$OUTPUT" | jq -e '.data.libc_location | length > 0' >/dev/null 2>&1; then
    assert_pass "libc_location present"
else
    assert_fail "libc_location present" "Empty or missing"
fi

# Test 8: heap object has start and end
if echo "$OUTPUT" | jq -e '.data.heap.start | length > 0' >/dev/null 2>&1; then
    assert_pass "heap.start present"
else
    assert_fail "heap.start present" "Empty or missing"
fi

if echo "$OUTPUT" | jq -e '.data.heap.end | length > 0' >/dev/null 2>&1; then
    assert_pass "heap.end present"
else
    assert_fail "heap.end present" "Empty or missing"
fi

# Test 9: stack object has start and end
if echo "$OUTPUT" | jq -e '.data.stack.start | length > 0' >/dev/null 2>&1; then
    assert_pass "stack.start present"
else
    assert_fail "stack.start present" "Empty or missing"
fi

if echo "$OUTPUT" | jq -e '.data.stack.end | length > 0' >/dev/null 2>&1; then
    assert_pass "stack.end present"
else
    assert_fail "stack.end present" "Empty or missing"
fi

# Test 10: ld_preload_recommendation is present and non-empty
if echo "$OUTPUT" | jq -e '.data.ld_preload_recommendation | length > 0' >/dev/null 2>&1; then
    assert_pass "ld_preload_recommendation present"
else
    assert_fail "ld_preload_recommendation present" "Empty or missing"
fi

# Test 11: type field is present and correct
if echo "$OUTPUT" | jq -e '.type == "memory-analysis"' >/dev/null 2>&1; then
    assert_pass "type field is 'memory-analysis'"
else
    assert_fail "type field is 'memory-analysis'" "Incorrect type value"
fi

# Test 12: unit field is "12"
if echo "$OUTPUT" | jq -e '.unit == "12"' >/dev/null 2>&1; then
    assert_pass "unit field is '12'"
else
    assert_fail "unit field is '12'" "Incorrect unit value"
fi

# Test 13: source is GROUND_TRUTH
if echo "$OUTPUT" | jq -e '.source == "GROUND_TRUTH"' >/dev/null 2>&1; then
    assert_pass "source is 'GROUND_TRUTH'"
else
    assert_fail "source is 'GROUND_TRUTH'" "Incorrect source value"
fi

# Test 14: error is null on success
if echo "$OUTPUT" | jq -e '.error == null' >/dev/null 2>&1; then
    assert_pass "error is null on success"
else
    assert_fail "error is null on success" "Error field not null"
fi

# Test 15: Check region categorization (ensure not all regions are "OTHER")
OTHER_COUNT=$(echo "$OUTPUT" | jq '[.data.memory_regions[] | select(.type == "OTHER")] | length' 2>/dev/null || echo 0)
TOTAL_COUNT=$(echo "$OUTPUT" | jq '.data.memory_regions | length' 2>/dev/null || echo 0)
if [[ $OTHER_COUNT -lt $TOTAL_COUNT ]]; then
    assert_pass "Regions properly categorized (not all OTHER)"
else
    assert_fail "Regions properly categorized" "All regions are OTHER type"
fi

# Cleanup
kill "$TEST_PID" 2>/dev/null || true

# Summary
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo -e "Results: ${GREEN}$PASSED passed${NC}, ${RED}$FAILED failed${NC}"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

exit $FAILED
