    cli_path = Path.home() / "node_modules/@anthropic-ai/claude-code/cli.js"

    if not cli_path.exists():
        return []

    # Read the file and extract process.env.* patterns
    try:
        with open(cli_path, 'r', errors='ignore') as f:
            content = f.read()
    except Exception as e:
        print(f"Warning: Could not read cli.js: {e}", file=sys.stderr)
        return []

