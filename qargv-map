def main():
    """Main entry point."""
    output_dir = Path.home() / "repo-staging/claude-code-control"
    output_dir.mkdir(parents=True, exist_ok=True)

    # Extract argv patterns
    argv_patterns = extract_argv_patterns()

    # Extract env vars
    env_vars = extract_env_vars()

    # Build argv map
    now_utc = datetime.now(timezone.utc).isoformat().replace('+00:00', 'Z')
    argv_map = {
        "type": "argv-analysis",
        "timestamp": now_utc,
        "unit": "11",
        "source": "claude-help-output + cli.js analysis",
        "data": {
            "entry_point": {
                "function": "main",
                "line": None,
                "description": "CLI entry point invoked with process.argv"
            },
            "option_parsing": {
                "library": "yargs (inferred from help output structure)",
                "line": None,
                "description": "Arguments parsed by yargs or similar CLI framework"
            },
            "argv_patterns": argv_patterns,
            "commands": [
                {
                    "name": "agents",
                    "description": "List configured agents",
                    "usage": "claude agents [options]"
                },
                {
                    "name": "auth",
                    "description": "Manage authentication",
                    "usage": "claude auth"
                },
                {
                    "name": "doctor",
                    "description": "Check the health of your Claude Code auto-updater",
                    "usage": "claude doctor"
                },
                {
                    "name": "install",
                    "description": "Install Claude Code native build",
                    "usage": "claude install [options] [target]"
                },
                {
                    "name": "mcp",
                    "description": "Configure and manage MCP servers",
                    "usage": "claude mcp"
                },
                {
                    "name": "plugin",
                    "description": "Manage Claude Code plugins",
                    "usage": "claude plugin"
                },
                {
                    "name": "setup-token",
                    "description": "Set up a long-lived authentication token",
                    "usage": "claude setup-token"
                },
                {
                    "name": "update|upgrade",
                    "description": "Check for updates and install if available",
                    "usage": "claude update"
                }
            ],
            "positional_arguments": [
                {
                    "name": "prompt",
                    "description": "Your prompt",
                    "position": "last",
                    "optional": True
                },
                {
                    "name": "command",
                    "description": "Subcommand to execute",
                    "position": "first",
                    "optional": True
                }
            ]
        },
        "error": None
    }

    # Build env map
    env_map = {
        "type": "env-analysis",
        "timestamp": now_utc,
        "unit": "11",
        "source": "cli.js grep + documentation",
        "data": {
            "env_vars": env_vars,
            "summary": {
                "total_vars": len(env_vars),
                "categories": {
                    "authentication": len([v for v in env_vars if any(x in v["name"] for x in ["API_KEY", "TOKEN", "AUTH", "CREDENTIAL"])]),
                    "claude_code_config": len([v for v in env_vars if v["name"].startswith("CLAUDE_CODE_")]),
                    "cloud_providers": len([v for v in env_vars if any(x in v["name"] for x in ["AWS_", "AZURE_", "GOOGLE_", "BEDROCK", "VERTEX"])]),
                    "system_environment": len([v for v in env_vars if v["name"] in ["HOME", "USER", "SHELL", "TERM", "PATH"]]),
                }
            }
        },
        "error": None
    }

    # Write argv map
    argv_path = output_dir / "cli-argv-map.json"
    with open(argv_path, 'w') as f:
        json.dump(argv_map, f, indent=2)
    print(f"✓ Created {argv_path}", file=sys.stderr)

    # Write env map
    env_path = output_dir / "cli-env-map.json"
    with open(env_path, 'w') as f:
        json.dump(env_map, f, indent=2)
    print(f"✓ Created {env_path}", file=sys.stderr)

    # Summary
    print(f"\nAnalysis Complete:", file=sys.stderr)
    print(f"  Argv patterns: {len(argv_patterns)}", file=sys.stderr)
    print(f"  Env variables: {len(env_vars)}", file=sys.stderr)
    print(f"  Subcommands: {len(argv_map['data']['commands'])}", file=sys.stderr)

    return 0

if __name__ == "__main__":
    sys.exit(main())
