                                 QC2: auto-approved + logged

  --autonomous-loop <task>       Run autonomous loop.
                                 QC0: FORBIDDEN
                                 QC1: auto-approved + rate-limited (100/hr)
                                 QC2: auto-approved + unlimited

  --delegate <task>              (NESTED_LOA) Create warrant for child delegation.
    --to <child_uuid>            Child agent to delegate to
    --with-loa <level>           Proposed autonomy level (0-10, default 4)
    [--trust <score>]            Trust score 0.0-1.0 (default 0.5)
    [--time-limit <secs>]        Task time limit in seconds (default 3600)
                                 QC0-1: FORBIDDEN (requires QC2_FULLY_AUTONOMOUS)
                                 QC2: auto-approved, warrant created + logged

QC_LEVEL DETERMINATION:
  QC_LEVEL is computed from LOA_CAP in $CLAUDE_GLOBAL_MD:
    LOA_CAP=2 → QC0_HUMAN_ONLY (safest)
    LOA_CAP=4 → QC1_SUPERVISED_LOOP
    LOA_CAP=6 → QC2_FULLY_AUTONOMOUS

OPTIONS:
  --help                         Show this help message
  --version                      Show version number

EXAMPLES:
  # List siblings of current session
  $SCRIPT_NAME --list-siblings

  # Resume session 22262eab with confirmation (QC0)
  $SCRIPT_NAME --resume 22262eab-... --confirm

  # Show lineage tree
  $SCRIPT_NAME --trace-lineage

  # Check distance to another session
  $SCRIPT_NAME --distance-to 22262eab-...

DESIGN REFERENCE:
  See: /home/aurora/.local/bin/qlaude.design

EOF
}

_show_version() {
  echo "$SCRIPT_NAME v$VERSION"
}

# --- NESTED_LOA Warrant Functions ---

# Validate a warrant from a parent agent
# Usage: _validate_warrant <warrant_file>
# Returns: JSON with {status: VALID|INVALID|EXPIRED, reason: ...}
_validate_warrant() {
  local warrant_file="$1"

  if [[ ! -f "$warrant_file" ]]; then
    python3 << 'PYJSON'
import json
print(json.dumps({
    "type": "warrant-validation",
    "status": "INVALID",
    "reason": "Warrant file not found"
}))
PYJSON
    return 1
  fi

  # Validate warrant JSON and fields
  WARRANT_FILE="$warrant_file" python3 << 'PYJSON'
import json
import os
from datetime import datetime, timezone

warrant_file = os.environ.get("WARRANT_FILE", "")

try:
  with open(warrant_file, 'r') as f:
    warrant = json.load(f)
except json.JSONDecodeError:
  print(json.dumps({
      "type": "warrant-validation",
      "status": "INVALID",
      "reason": "Warrant is not valid JSON"
  }))
  sys.exit(1)

# Check required fields
required_fields = ["warrant_id", "parent_uuid", "child_uuid", "proposed_loa_cap", "expires_at", "parent_loa_cap"]
missing = [f for f in required_fields if f not in warrant]
if missing:
  print(json.dumps({
      "type": "warrant-validation",
      "status": "INVALID",
      "reason": f"Missing required fields: {', '.join(missing)}"
  }))
  sys.exit(1)

# Check expiration
expires_at = datetime.fromisoformat(warrant["expires_at"].replace("Z", "+00:00"))
now = datetime.now(timezone.utc)
if now > expires_at:
  print(json.dumps({
      "type": "warrant-validation",
      "status": "EXPIRED",
      "reason": f"Warrant expired at {warrant['expires_at']}"
  }))
  sys.exit(0)

# Validate LOA hierarchy
if warrant["proposed_loa_cap"] > warrant["parent_loa_cap"]:
  print(json.dumps({
      "type": "warrant-validation",
      "status": "INVALID",
      "reason": f"Proposed LOA_CAP {warrant['proposed_loa_cap']} exceeds parent LOA_CAP {warrant['parent_loa_cap']}"
  }))
  sys.exit(0)

# Warranty is valid
print(json.dumps({
    "type": "warrant-validation",
    "status": "VALID",
    "warrant_id": warrant["warrant_id"],
    "parent_uuid": warrant["parent_uuid"],
    "child_uuid": warrant["child_uuid"],
    "proposed_loa_cap": warrant["proposed_loa_cap"],
    "parent_loa_cap": warrant["parent_loa_cap"],
    "task_description": warrant.get("task_description", ""),
    "expires_at": warrant["expires_at"],
    "reason": "Warrant is valid and not expired"
}))
PYJSON
}

# Child-side: Accept a warrant from parent
# Usage: _accept_warrant <warrant_file> [--accept | --counter-propose <loa>]
# Returns: JSON acceptance record
_accept_warrant() {
  local warrant_file="$1"
  local action="${2:-}"

  if [[ ! -f "$warrant_file" ]]; then
    _error "Warrant file not found: $warrant_file"
  fi

  # First validate the warrant
  local validation
  validation=$(_validate_warrant "$warrant_file")

  if ! echo "$validation" | grep -q '"status": "VALID"'; then
    _log "Warrant validation failed: $validation"
    return 1
  fi

  # Parse warrant details
  local warrant_id parent_uuid proposed_loa_cap
  warrant_id=$(grep -o '"warrant_id": "[^"]*"' "$warrant_file" | cut -d'"' -f4)
  parent_uuid=$(grep -o '"parent_uuid": "[^"]*"' "$warrant_file" | cut -d'"' -f4)
  proposed_loa_cap=$(grep -o '"proposed_loa_cap": [0-9]*' "$warrant_file" | cut -d' ' -f2)

  # Get current child LOA
  local child_loa
  child_loa=$(grep "^LOA_CAP=" "$CLAUDE_GLOBAL_MD" 2>/dev/null | cut -d= -f2) || child_loa=2

  # Determine acceptance status
  local accepted_loa status reason
  if [[ "$action" == "--counter-propose" ]]; then
    local counter_loa="${3:-}"
    [[ -n "$counter_loa" ]] || _error "Counter-proposal requires LOA value"
    if (( counter_loa > proposed_loa_cap )); then
      _error "Cannot counter-propose LOA_CAP=$counter_loa (exceeds parent proposal of $proposed_loa_cap)"
    fi
    accepted_loa="$counter_loa"
    status="NEGOTIATED"
    reason="Child counter-proposed LOA_CAP=$counter_loa (parent proposed $proposed_loa_cap)"
  elif (( child_loa >= proposed_loa_cap )); then
    # Child can handle the proposed LOA
    accepted_loa="$proposed_loa_cap"
    status="ACCEPTED"
    reason="Child can handle proposed LOA_CAP=$proposed_loa_cap"
  else
    # Child cannot handle the proposed LOA
    accepted_loa="$child_loa"
    status="NEGOTIATED"
    reason="Child can only handle LOA_CAP=$child_loa (parent proposed $proposed_loa_cap)"
  fi

  # Create acceptance record
  _ensure_aurora_agent_dir

  # Create acceptance JSONL record
  local acceptance_dir="${WARRANTS_DIR}/acceptances"
  mkdir -p "$acceptance_dir"

  local acceptance_file="$acceptance_dir/${warrant_id}_acceptance.jsonl"

  # Write acceptance record
  python3 << PYJSON > "$acceptance_file"
import json
from datetime import datetime, timezone

acceptance = {
    "type": "loa_acceptance",
    "warrant_id": "$warrant_id",
    "parent_uuid": "$parent_uuid",
    "child_uuid": "$(cat "$AURORA_AGENT_DIR/home-session-id" 2>/dev/null || echo 'unknown')",
    "proposed_loa_cap": $proposed_loa_cap,
    "accepted_loa_cap": $accepted_loa,
    "status": "$status",
    "reason": "$reason",
    "child_loa_cap": $child_loa,
    "timestamp": datetime.now(timezone.utc).isoformat().replace("+00:00", "Z")
}

print(json.dumps(acceptance))
PYJSON

  _log "Warrant acceptance recorded: $acceptance_file"
  _log "Status: $status (accepted_loa=$accepted_loa)"

  # Log to audit trail (with parent context)
  _audit_log "warrant-accept" "$warrant_id" "$status" "$(( child_loa / 2 ))" "$child_loa" "$reason" "$parent_uuid" "$warrant_id"

  # Return acceptance details
  cat "$acceptance_file"
}

# Create a warrant for delegating autonomy to a child agent
# Usage: _create_warrant <child_uuid> <task_description> <proposed_loa_cap> <trust_score> [time_limit_secs]
_create_warrant() {
  local child_uuid="$1"
  local task_description="$2"
  local proposed_loa_cap="$3"
  local trust_score="${4:-0.5}"
  local time_limit_secs="${5:-3600}"

  # Validate inputs
  if [[ ! "$child_uuid" =~ ^[a-f0-9-]{36}$ ]]; then
    _error "Invalid child UUID format: $child_uuid"
  fi

  if ! [[ "$proposed_loa_cap" =~ ^[0-9]+$ ]] || (( proposed_loa_cap < 0 || proposed_loa_cap > 10 )); then
    _error "Invalid LOA_CAP: $proposed_loa_cap (must be 0-10)"
  fi

  # Get parent LOA
  local parent_loa
  parent_loa=$(grep "^LOA_CAP=" "$CLAUDE_GLOBAL_MD" 2>/dev/null | cut -d= -f2) || parent_loa=2

  if (( proposed_loa_cap > parent_loa )); then
    _error "Cannot propose LOA_CAP=$proposed_loa_cap (parent LOA_CAP=$parent_loa)"
  fi

  # Create warrant directory
  mkdir -p "$WARRANTS_DIR"

  # Generate warrant ID (UUID-based)
  local warrant_id
  warrant_id=$(python3 -c "import uuid; print(str(uuid.uuid4()))")

  # Create warrant JSON
  local warrant_file="$WARRANTS_DIR/$warrant_id.json"
  local expires_at
  expires_at=$(python3 << 'PYDATE'
from datetime import datetime, timedelta, timezone
expires = datetime.now(timezone.utc) + timedelta(hours=1)
print(expires.isoformat().replace("+00:00", "Z"))
PYDATE
  )

  local parent_uuid
  parent_uuid=$(cat "$AURORA_AGENT_DIR/home-session-id" 2>/dev/null || echo "unknown")

  # Write warrant
  python3 << PYJSON > "$warrant_file"
import json
from datetime import datetime, timezone

warrant = {
    "type": "loa_proposal",
    "warrant_id": "$warrant_id",
    "parent_uuid": "$parent_uuid",
    "child_uuid": "$child_uuid",
    "task_description": "$task_description",
    "proposed_loa_cap": $proposed_loa_cap,
    "trust_score": $trust_score,
    "time_limit_seconds": $time_limit_secs,
    "created_at": datetime.now(timezone.utc).isoformat().replace("+00:00", "Z"),
    "expires_at": "$expires_at",
    "parent_loa_cap": $parent_loa
}

print(json.dumps(warrant, indent=2))
PYJSON

  _log "Warrant created: $warrant_file"
  _log "Warrant ID: $warrant_id"
  _log "Child UUID: $child_uuid"
  _log "Proposed LOA_CAP: $proposed_loa_cap (parent LOA_CAP: $parent_loa)"
  _log "Trust score: $trust_score"
  _log "Expires at: $expires_at"

  # Log warrant creation to audit trail (with warrant context)
  _audit_log "warrant-create" "$warrant_id" "PROPOSED" "$(( parent_loa / 2 ))" "$parent_loa" "Delegating task to $child_uuid with LOA_CAP=$proposed_loa_cap" "$parent_uuid" "$warrant_id"

  # Output warrant details
  echo "{\"warrant_id\": \"$warrant_id\", \"warrant_file\": \"$warrant_file\"}"
}

# --- Main Dispatch ---

main() {
  local command="${1:-}"

  case "$command" in
    --help|-h)
      _show_help
      exit 0
      ;;

    --version|-v)
      _show_version
      exit 0
      ;;

    --list-siblings)
      local uuid="${2:-}"
      if [[ -z "$uuid" ]]; then
        uuid=$(cat "$AURORA_AGENT_DIR/home-session-id" 2>/dev/null) || {
          _error "Could not determine current session UUID"
        }
      fi
      _log "Listing siblings of $uuid..."
      _list_siblings "$uuid" || _error "Could not find siblings for $uuid"
      ;;

    --distance-to)
      local target="${2:-}"
      [[ -n "$target" ]] || _error "--distance-to requires a UUID argument"
      local from="${3:-}"
      _log "Computing distance from ${from:-current} to $target..."
      _distance_to "$target" "$from" || exit 1
      ;;

    --trace-lineage)
      local uuid="${2:-}"
      _log "Tracing lineage from ${uuid:-current session}..."
      _trace_lineage "$uuid" || exit 1
      ;;

    --resume)
      local target="${2:-}"
      [[ -n "$target" ]] || _error "--resume requires a UUID argument"
      local confirm="${3:-}"
      local qc_level
      local loa_cap
      qc_level=$(_get_qc_level)
      loa_cap=$(grep "^LOA_CAP=" "$CLAUDE_GLOBAL_MD" 2>/dev/null | cut -d= -f2) || loa_cap=2
      _check_agents_md "resume" || _log "WARNING: AGENTS.md authorization check failed for resume"
      _resume_session "$target" "$confirm" "$qc_level" "$loa_cap"
      ;;

    --fork)
      local parent="${2:-}"
      [[ -n "$parent" ]] || _error "--fork requires a UUID argument"
      local confirm="${3:-}"
      local qc_level
      local loa_cap
      qc_level=$(_get_qc_level)
      loa_cap=$(grep "^LOA_CAP=" "$CLAUDE_GLOBAL_MD" 2>/dev/null | cut -d= -f2) || loa_cap=2
      _check_agents_md "fork" || _log "WARNING: AGENTS.md authorization check failed for fork"
      _fork_session "$parent" "$confirm" "$qc_level" "$loa_cap"
      ;;

    --autonomous-loop)
      local task="${2:-}"
      [[ -n "$task" ]] || _error "--autonomous-loop requires a task description"
      local qc_level
      local loa_cap
      qc_level=$(_get_qc_level)
      loa_cap=$(grep "^LOA_CAP=" "$CLAUDE_GLOBAL_MD" 2>/dev/null | cut -d= -f2) || loa_cap=2
      _check_agents_md "autonomous-loop" || _log "WARNING: AGENTS.md authorization check failed for autonomous-loop"
      _autonomous_loop "$task" "$qc_level" "$loa_cap"
      ;;

    --delegate)
      # NESTED_LOA: Delegate task to child with proposed autonomy level
      # Usage: qlaude --delegate <task> --to <child_uuid> --with-loa <level>
      local task="${2:-}"
      local child_uuid=""
      local proposed_loa=4  # Default: supervised level
      local trust_score=0.5  # Default: moderate trust
      local time_limit=3600  # Default: 1 hour

      [[ -n "$task" ]] || _error "--delegate requires task description as first argument"

      # Parse remaining arguments
      shift 2
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --to)
            child_uuid="${2:-}"
            [[ -n "$child_uuid" ]] || _error "--to requires a UUID"
            shift 2
            ;;
          --with-loa)
            proposed_loa="${2:-}"
            shift 2
            ;;
          --trust)
            trust_score="${2:-}"
            shift 2
            ;;
          --time-limit)
            time_limit="${2:-}"
            shift 2
            ;;
          *)
            _error "Unknown argument in --delegate: $1"
            ;;
        esac
      done

      [[ -n "$child_uuid" ]] || _error "--delegate requires --to <child_uuid>"

      local qc_level
      local loa_cap
      qc_level=$(_get_qc_level)
      loa_cap=$(grep "^LOA_CAP=" "$CLAUDE_GLOBAL_MD" 2>/dev/null | cut -d= -f2) || loa_cap=2

      # Require QC2 (fully autonomous) to create warrants
      if (( qc_level < 2 )); then
        _audit_log "warrant-create" "$child_uuid" "REJECTED" "$qc_level" "$loa_cap" "Only QC2_FULLY_AUTONOMOUS can create warrants"
        _error "Warrant creation requires QC_LEVEL=2 (FULLY_AUTONOMOUS), but current is QC$qc_level"
      fi

      _check_agents_md "delegate" || _log "WARNING: AGENTS.md authorization check failed for delegate"
      _create_warrant "$child_uuid" "$task" "$proposed_loa" "$trust_score" "$time_limit"
      ;;

    --validate-warrant)
      # NESTED_LOA: Validate a warrant file
      # Usage: qlaude --validate-warrant <warrant_file>
      local warrant_file="${2:-}"
      [[ -n "$warrant_file" ]] || _error "--validate-warrant requires a warrant file path"

      if [[ ! -f "$warrant_file" ]]; then
        _error "Warrant file not found: $warrant_file"
      fi

      _validate_warrant "$warrant_file"
      ;;

    --accept-warrant)
      # NESTED_LOA: Child accepts a warrant from parent
      # Usage: qlaude --accept-warrant <warrant_file> [--accept | --counter-propose <loa>]
      local warrant_file="${2:-}"
      [[ -n "$warrant_file" ]] || _error "--accept-warrant requires a warrant file path"

      if [[ ! -f "$warrant_file" ]]; then
        _error "Warrant file not found: $warrant_file"
      fi

      # Check if counter-proposing
      local action="${3:-}"
      if [[ "$action" == "--counter-propose" ]]; then
        _accept_warrant "$warrant_file" "$action" "${4:-}"
      else
        _accept_warrant "$warrant_file" "${action:---accept}"
      fi
      ;;

    "")
      _show_help
      exit 1
      ;;

    *)
      _error "Unknown command: $command (try --help)"
      ;;
  esac
}

main "$@"
