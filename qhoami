#!/usr/bin/env bash
# qhoami — Aurora Claude Code Control Plane Identity Sensor
#
# Reads ground truth about a Claude Code instance's identity across seven dimensions:
# 1. AVATAR: workspace (HOME, DOWNLOADS, UNDERBAR, DUNDERBAR, THUNDERBAR, CUSTOM)
# 2. SIDECAR: lineage relationship (NONE, AUTONOMY, PARALLEL, CHILD, UNKNOWN)
# 3. GENERATION: reboot count (0, 1, 2, ..., or UNKNOWN)
# 4. MODEL: which Claude (HAIKU, SONNET, OPUS, LOCAL, UNKNOWN)
# 5. QC_LEVEL: autonomy authorization (0_HUMAN_ONLY, 1_SUPERVISED, 2_AUTONOMOUS, UNKNOWN)
# 6. MEMORY_SCOPE: context availability (NONE, FILE_ONLY, RESUMED, COMPACTED, UNKNOWN)
# 7. LOCATION: physical host (AURORA_LOCAL, LAN_CARVIO, LAN_OTHER, REMOTE, UNKNOWN)
#
# Usage:
#   qhoami --self              # Identity of current Claude session
#   qhoami <UUID>              # Identity of specific session UUID
#   qhoami --all               # All running Claude instances
#   qhoami --enum-values       # Print all enum definitions
#
# Exit codes: 0=success, 1=not found, 2=usage error

set -euo pipefail

# ─── ENUM DEFINITIONS ─────────────────────────────────────────

# AVATAR enums (workspace orientation)
declare -rA AVATAR_ENUM=(
  [1]="AVATAR_HOME"
  [2]="AVATAR_DOWNLOADS"
  [3]="AVATAR_UNDERBAR"
  [4]="AVATAR_DUNDERBAR"
  [5]="AVATAR_THUNDERBAR"
  [6]="AVATAR_CUSTOM"
)

# SIDECAR enums (lineage relationship)
declare -rA SIDECAR_ENUM=(
  [0]="SIDECAR_NONE"
  [1]="SIDECAR_AUTONOMY"
  [2]="SIDECAR_PARALLEL"
  [3]="SIDECAR_CHILD"
  [9]="SIDECAR_UNKNOWN"
)

# GENERATION enums (reboot count)
# 0..N are valid, UNKNOWN=9

# MODEL enums (which Claude)
declare -rA MODEL_ENUM=(
  [1]="MODEL_HAIKU"
  [2]="MODEL_SONNET"
  [3]="MODEL_OPUS"
  [4]="MODEL_LOCAL"
  [9]="MODEL_UNKNOWN"
)

# QC_LEVEL enums (autonomy level)
declare -rA QC_LEVEL_ENUM=(
  [0]="QC0_HUMAN_ONLY"
  [1]="QC1_SUPERVISED"
  [2]="QC2_FULLY_AUTONOMOUS"
  [9]="QC_UNKNOWN"
)

# MEMORY_SCOPE enums (context availability)
declare -rA MEMORY_ENUM=(
  [0]="MEM_NONE"
  [1]="MEM_FILE_ONLY"
  [2]="MEM_RESUMED"
  [3]="MEM_COMPACTED"
  [9]="MEM_UNKNOWN"
)

# LOCATION enums (physical host)
declare -rA LOCATION_ENUM=(
  [1]="LOC_AURORA_LOCAL"
  [2]="LOC_LAN_CARVIO"
  [3]="LOC_LAN_OTHER"
  [4]="LOC_REMOTE"
  [9]="LOC_UNKNOWN"
)

# ─── PATHS ────────────────────────────────────────────────────

TASKS_DIR="$HOME/.claude/tasks"
PROJECT_DIR="$HOME/.claude/projects"
AURORA_CONFIG="$HOME/CLAUDE.md"
GLOBAL_CONFIG="$HOME/.claude/CLAUDE.md"

# ─── HELPER FUNCTIONS ─────────────────────────────────────────

_json_escape() {
  local str="$1"
  str="${str//\\/\\\\}"
  str="${str//\"/\\\"}"
  str="${str//$'\n'/\\n}"
  echo "$str"
}

_json_obj_start() {
  echo "  \"$1\": {"
}

_json_obj_end() {
  if [[ "${1:-}" == "last" ]]; then
    echo "  }"
  else
    echo "  },"
  fi
}

_json_string_field() {
  local key="$1"
  local value="$2"
  local last="${3:-}"
  value=$(_json_escape "$value")
  if [[ "$last" == "last" ]]; then
    echo "    \"$key\": \"$value\""
  else
    echo "    \"$key\": \"$value\","
  fi
}

# Find claude ancestor process
_find_claude_pid() {
  local pid="${1:-$$}"
  local depth=0
  while (( depth < 20 )); do
    comm=$(ps -o comm= -p "$pid" 2>/dev/null) || break
    if [[ "$comm" == "claude" ]]; then
      echo "$pid"
      return 0
    fi
    pid=$(ps -o ppid= -p "$pid" 2>/dev/null | tr -d ' ') || break
    [[ -n "$pid" && "$pid" -gt 1 ]] || break
    depth=$(( depth + 1 ))
  done
  return 1
}

# Find session UUID via inotify mechanism (from aurora-session-id)
_find_session_uuid() {
  local claude_pid="$1"
  for fd_path in /proc/$claude_pid/fd/*; do
    target=$(readlink "$fd_path" 2>/dev/null) || continue
    [[ "$target" == "anon_inode:inotify" ]] || continue
    fd_num=$(basename "$fd_path")
    while IFS= read -r line; do
      ino_hex=$(printf '%s' "$line" | grep -o 'ino:[0-9a-f]*' | cut -d: -f2) || continue
      [[ -n "$ino_hex" ]] || continue
      ino_dec=$((16#$ino_hex)) 2>/dev/null || continue
      for tasks_subdir in "$TASKS_DIR"/*/; do
        [[ -d "$tasks_subdir" ]] || continue
        subdir_ino=$(stat -c %i "$tasks_subdir" 2>/dev/null) || continue
        if [[ "$subdir_ino" == "$ino_dec" ]]; then
          basename "$tasks_subdir"
          return 0
        fi
      done
    done < /proc/$claude_pid/fdinfo/$fd_num 2>/dev/null
  done
  return 1
}

# Find JSONL file with most records for this sessionId
_find_jsonl() {
  local uuid="$1"
  local best_jsonl=""
  local best_count=0
  for f in "$PROJECT_DIR"/*/*.jsonl; do
    [[ -f "$f" ]] || continue
    count=$(grep -c "\"sessionId\".*\"$uuid\"" "$f" 2>/dev/null) || count=0
    if [[ "$count" -gt "$best_count" ]]; then
      best_count=$count
      best_jsonl="$f"
    fi
  done
  if [[ -n "$best_jsonl" ]]; then
    echo "$best_jsonl"
  fi
}

# ─── DIMENSION SENSORS ────────────────────────────────────────

_sense_avatar() {
  local uuid="$1"
  local claude_pid="$2"

  # Ground truth: /proc/{PID}/cwd
  local cwd
  cwd=$(readlink /proc/$claude_pid/cwd 2>/dev/null) || cwd="?"

  # Config override: CLAUDE_CODE_WORKSPACE env var or instance-config.json
  # (For now, just read cwd)

  local avatar_val=""
  local source_note=""

  case "$cwd" in
    "$HOME/Downloads"*)
      avatar_val="AVATAR_DOWNLOADS"
      source_note="/proc/$claude_pid/cwd = $cwd (GROUND_TRUTH)"
      ;;
    "$HOME/_"*)
      avatar_val="AVATAR_UNDERBAR"
      source_note="/proc/$claude_pid/cwd = $cwd (GROUND_TRUTH)"
      ;;
    "$HOME/__"*)
      avatar_val="AVATAR_DUNDERBAR"
      source_note="/proc/$claude_pid/cwd = $cwd (GROUND_TRUTH)"
      ;;
    "$HOME/___"*)
      avatar_val="AVATAR_THUNDERBAR"
      source_note="/proc/$claude_pid/cwd = $cwd (GROUND_TRUTH)"
      ;;
    "$HOME"*)
      avatar_val="AVATAR_HOME"
      source_note="/proc/$claude_pid/cwd = $cwd (GROUND_TRUTH)"
      ;;
    *)
      avatar_val="AVATAR_CUSTOM"
      source_note="/proc/$claude_pid/cwd = $cwd (GROUND_TRUTH)"
      ;;
  esac

  echo "$avatar_val|GROUND_TRUTH|$source_note"
}

_sense_sidecar() {
  local uuid="$1"
  local jsonl="$2"

  # Ground truth: parentUuid field in first JSONL record with this sessionId
  local parent_uuid
  parent_uuid=$(python3 -c "
import json
with open('$jsonl') as f:
    for line in f:
        try:
            r = json.loads(line)
            if r.get('sessionId') == '$uuid':
                parent = r.get('parentUuid')
                if parent is None:
                    print('null')
                else:
                    print(parent)
                break
        except: pass
" 2>/dev/null || echo "?")

  # Config override: .role file in tasks dir
  local config_role
  config_role=$(cat "$TASKS_DIR/$uuid/.role" 2>/dev/null || echo "")

  local sidecar_val=""
  local source_type=""
  local source_note=""

  if [[ -n "$config_role" ]]; then
    sidecar_val="$config_role"
    source_type="CONFIG"
    source_note="$TASKS_DIR/$uuid/.role (CONFIG)"
  elif [[ "$parent_uuid" == "null" ]]; then
    sidecar_val="SIDECAR_NONE"
    source_type="GROUND_TRUTH"
    source_note="parentUuid is null in JSONL (GROUND_TRUTH)"
  elif [[ "$parent_uuid" == "?" ]]; then
    sidecar_val="SIDECAR_UNKNOWN"
    source_type="HEURISTIC_FALLBACK"
    source_note="could not determine parentUuid from JSONL (HEURISTIC_FALLBACK)"
  else
    # Parent exists; check if it's autonomy, parallel, or child
    # For now, default to SIDECAR_CHILD
    sidecar_val="SIDECAR_CHILD"
    source_type="GROUND_TRUTH"
    source_note="parentUuid=$parent_uuid exists in JSONL (GROUND_TRUTH)"
  fi

  echo "$sidecar_val|$source_type|$source_note"
}

_sense_generation() {
  local uuid="$1"
  local jsonl="$2"

  # Config override: .generation file in tasks dir
  local config_gen
  config_gen=$(cat "$TASKS_DIR/$uuid/.generation" 2>/dev/null || echo "")

  if [[ -n "$config_gen" ]]; then
    echo "$config_gen|CONFIG|$TASKS_DIR/$uuid/.generation"
    return
  fi

  # Ground truth: count ancestor sessionIds in JSONL via parentUuid chain
  # If parent doesn't appear in JSONL, it was compacted; increment generation
  local generation=0
  local current_parent
  current_parent=$(python3 -c "
import json
with open('$jsonl') as f:
    for line in f:
        try:
            r = json.loads(line)
            if r.get('sessionId') == '$uuid':
                parent = r.get('parentUuid')
                if parent is None:
                    print('null')
                else:
                    print(parent)
                break
        except: pass
" 2>/dev/null || echo "?")

  local source_note="no compacted ancestors in JSONL (GROUND_TRUTH)"

  if [[ "$current_parent" != "null" && "$current_parent" != "?" ]]; then
    # Check if parent exists in JSONL
    local parent_exists
    parent_exists=$(grep -c "\"sessionId\".*\"$current_parent\"" "$jsonl" 2>/dev/null) || parent_exists=0
    if [[ "$parent_exists" -eq 0 ]]; then
      generation=1
      source_note="parent $current_parent not in JSONL; at least 1 compaction (HEURISTIC_FALLBACK)"
    fi
  fi

  echo "GEN_$generation|GROUND_TRUTH|$source_note"
}

_sense_model() {
  local uuid="$1"

  # Config override: instance-config.json or ANTHROPIC_MODEL env
  local config_model=""
  if [[ -f "$HOME/.aurora-agent/instance-config.json" ]]; then
    config_model=$(python3 -c "
import json
try:
    with open('$HOME/.aurora-agent/instance-config.json') as f:
        cfg = json.load(f)
        print(cfg.get('model', ''))
except: pass
" 2>/dev/null)
  fi

  if [[ -n "$config_model" ]]; then
    echo "$config_model|CONFIG|$HOME/.aurora-agent/instance-config.json"
    return
  fi

  # Ground truth: ANTHROPIC_MODEL environment variable (if available in process env)
  # Note: can't reliably read from /proc/{PID}/environ without access
  # For now, default to UNKNOWN

  echo "MODEL_UNKNOWN|HEURISTIC_FALLBACK|Could not determine model from config or env"
}

_sense_qc_level() {
  local uuid="$1"

  # Config override: LOA_CAP in ~/CLAUDE.md or ~/.claude/CLAUDE.md
  local loa_cap=""
  local source_file=""
  if [[ -f "$AURORA_CONFIG" ]]; then
    loa_cap=$(grep "^LOA_CAP=" "$AURORA_CONFIG" 2>/dev/null | cut -d= -f2 | tr -d ' ') || true
    if [[ -n "$loa_cap" ]]; then
      source_file="$AURORA_CONFIG"
    fi
  fi
  if [[ -z "$loa_cap" && -f "$GLOBAL_CONFIG" ]]; then
    loa_cap=$(grep "^LOA_CAP=" "$GLOBAL_CONFIG" 2>/dev/null | cut -d= -f2 | tr -d ' ') || true
    if [[ -n "$loa_cap" ]]; then
      source_file="$GLOBAL_CONFIG"
    fi
  fi

  local qc_val="QC0_HUMAN_ONLY"
  local source_type="HEURISTIC_FALLBACK"
  local source_note="interactive terminal (HEURISTIC_FALLBACK)"

  if [[ -n "$loa_cap" ]]; then
    case "$loa_cap" in
      0) qc_val="QC0_HUMAN_ONLY" ;;
      1) qc_val="QC1_SUPERVISED" ;;
      2) qc_val="QC2_FULLY_AUTONOMOUS" ;;
      *) qc_val="QC_UNKNOWN" ;;
    esac
    source_type="CONFIG"
    source_note="LOA_CAP=$loa_cap in $source_file (CONFIG)"
  fi

  echo "$qc_val|$source_type|$source_note"
}

_sense_memory() {
  local uuid="$1"
  local jsonl="$2"

  # Config override: memory-config.json
  local config_mem=""
  if [[ -f "$HOME/.aurora-agent/memory-config.json" ]]; then
    config_mem=$(python3 -c "
import json
try:
    with open('$HOME/.aurora-agent/memory-config.json') as f:
        cfg = json.load(f)
        print(cfg.get('memory_scope', ''))
except: pass
" 2>/dev/null)
  fi

  if [[ -n "$config_mem" ]]; then
    echo "$config_mem|CONFIG|$HOME/.aurora-agent/memory-config.json"
    return
  fi

  # Ground truth: JSONL line count and first/last timestamp
  local line_count
  line_count=$(grep -c "\"sessionId\".*\"$uuid\"" "$jsonl" 2>/dev/null) || line_count=0

  local memory_val=""
  local source_type=""
  local source_note=""

  if [[ "$line_count" -eq 0 ]]; then
    memory_val="MEM_NONE"
    source_type="GROUND_TRUTH"
    source_note="no records for $uuid in JSONL (GROUND_TRUTH)"
  elif [[ "$line_count" -lt 10 ]]; then
    # Small conversation, likely FILE_ONLY or fresh start
    memory_val="MEM_FILE_ONLY"
    source_type="HEURISTIC_FALLBACK"
    source_note="$line_count records in JSONL (HEURISTIC_FALLBACK)"
  else
    # Larger conversation, likely resumed
    memory_val="MEM_RESUMED"
    source_type="HEURISTIC_FALLBACK"
    source_note="$line_count records in JSONL (HEURISTIC_FALLBACK)"
  fi

  echo "$memory_val|$source_type|$source_note"
}

_sense_location() {
  local uuid="$1"

  # Config override: CLAUDE_CODE_HOST_ID or instance-config.json
  local config_loc=""
  if [[ -f "$HOME/.aurora-agent/instance-config.json" ]]; then
    config_loc=$(python3 -c "
import json
try:
    with open('$HOME/.aurora-agent/instance-config.json') as f:
        cfg = json.load(f)
        print(cfg.get('location', ''))
except: pass
" 2>/dev/null)
  fi

  if [[ -n "$config_loc" ]]; then
    echo "$config_loc|CONFIG|$HOME/.aurora-agent/instance-config.json"
    return
  fi

  # Ground truth: hostname
  local hostname
  hostname=$(hostname 2>/dev/null || echo "?")

  local location_val=""
  local source_type=""
  local source_note=""

  case "$hostname" in
    aurora)
      location_val="LOC_AURORA_LOCAL"
      source_type="GROUND_TRUTH"
      source_note="hostname = $hostname (GROUND_TRUTH)"
      ;;
    CARVIO|carvio)
      location_val="LOC_LAN_CARVIO"
      source_type="GROUND_TRUTH"
      source_note="hostname = $hostname (GROUND_TRUTH)"
      ;;
    *)
      location_val="LOC_UNKNOWN"
      source_type="HEURISTIC_FALLBACK"
      source_note="hostname = $hostname (HEURISTIC_FALLBACK)"
      ;;
  esac

  echo "$location_val|$source_type|$source_note"
}

# ─── IDENTITY BUILDER ─────────────────────────────────────────

_build_identity() {
  local uuid="$1"
  local claude_pid="$2"

  # Find JSONL
  local jsonl
  jsonl=$(_find_jsonl "$uuid") || jsonl=""

  if [[ -z "$jsonl" ]]; then
    echo "ERROR: could not find JSONL for UUID $uuid" >&2
    return 1
  fi

  # Sense each dimension
  IFS='|' read -r avatar_val avatar_src avatar_note < <(_sense_avatar "$uuid" "$claude_pid")
  IFS='|' read -r sidecar_val sidecar_src sidecar_note < <(_sense_sidecar "$uuid" "$jsonl")
  IFS='|' read -r gen_val gen_src gen_note < <(_sense_generation "$uuid" "$jsonl")
  IFS='|' read -r model_val model_src model_note < <(_sense_model "$uuid")
  IFS='|' read -r qc_val qc_src qc_note < <(_sense_qc_level "$uuid")
  IFS='|' read -r mem_val mem_src mem_note < <(_sense_memory "$uuid" "$jsonl")
  IFS='|' read -r loc_val loc_src loc_note < <(_sense_location "$uuid")

  # Build birth timestamp
  local born
  born=$(python3 -c "
import json
with open('$jsonl') as f:
    for line in f:
        try:
            r = json.loads(line)
            if r.get('sessionId') == '$uuid' and r.get('timestamp'):
                print(r['timestamp'])
                break
        except: pass
" 2>/dev/null || echo "?")

  # Build JSON output
  cat <<EOF
{
  "uuid": "$uuid",
  "pid": $claude_pid,
  "birth_timestamp": "$born",
  "avatar": {
EOF
  _json_string_field "value" "$avatar_val"
  _json_string_field "source" "$avatar_src"
  _json_string_field "from" "$avatar_note" "last"
  cat <<EOF
  },
  "sidecar": {
EOF
  _json_string_field "value" "$sidecar_val"
  _json_string_field "source" "$sidecar_src"
  _json_string_field "from" "$sidecar_note" "last"
  cat <<EOF
  },
  "generation": {
EOF
  _json_string_field "value" "$gen_val"
  _json_string_field "source" "$gen_src"
  _json_string_field "from" "$gen_note" "last"
  cat <<EOF
  },
  "model": {
EOF
  _json_string_field "value" "$model_val"
  _json_string_field "source" "$model_src"
  _json_string_field "from" "$model_note" "last"
  cat <<EOF
  },
  "qc_level": {
EOF
  _json_string_field "value" "$qc_val"
  _json_string_field "source" "$qc_src"
  _json_string_field "from" "$qc_note" "last"
  cat <<EOF
  },
  "memory_scope": {
EOF
  _json_string_field "value" "$mem_val"
  _json_string_field "source" "$mem_src"
  _json_string_field "from" "$mem_note" "last"
  cat <<EOF
  },
  "location": {
EOF
  _json_string_field "value" "$loc_val"
  _json_string_field "source" "$loc_src"
  _json_string_field "from" "$loc_note" "last"
  cat <<EOF
  },
  "jsonl": "$jsonl"
}
EOF
}

# ─── ENUM PRINTER ────────────────────────────────────────────

_print_enum_values() {
  cat <<'EOF'
# AVATAR enums (workspace orientation)
AVATAR_HOME       = 1
AVATAR_DOWNLOADS  = 2
AVATAR_UNDERBAR   = 3
AVATAR_DUNDERBAR  = 4
AVATAR_THUNDERBAR = 5
AVATAR_CUSTOM     = 6

# SIDECAR enums (lineage relationship)
SIDECAR_NONE       = 0
SIDECAR_AUTONOMY   = 1
SIDECAR_PARALLEL   = 2
SIDECAR_CHILD      = 3
SIDECAR_UNKNOWN    = 9

# GENERATION enums (reboot count)
GEN_0, GEN_1, GEN_2, ... = reboot count (any non-negative integer)
GEN_UNKNOWN = 9

# MODEL enums (which Claude)
MODEL_HAIKU   = 1
MODEL_SONNET  = 2
MODEL_OPUS    = 3
MODEL_LOCAL   = 4
MODEL_UNKNOWN = 9

# QC_LEVEL enums (autonomy level)
QC0_HUMAN_ONLY         = 0
QC1_SUPERVISED         = 1
QC2_FULLY_AUTONOMOUS   = 2
QC_UNKNOWN             = 9

# MEMORY_SCOPE enums (context availability)
MEM_NONE      = 0
MEM_FILE_ONLY = 1
MEM_RESUMED   = 2
MEM_COMPACTED = 3
MEM_UNKNOWN   = 9

# LOCATION enums (physical host)
LOC_AURORA_LOCAL = 1
LOC_LAN_CARVIO   = 2
LOC_LAN_OTHER    = 3
LOC_REMOTE       = 4
LOC_UNKNOWN      = 9

# SOURCE types
GROUND_TRUTH       = read directly from filesystem/inotify/proc
CONFIG             = from config file override (.role, .generation, CLAUDE.md, etc)
HEURISTIC_FALLBACK = inferred from context when ground truth unavailable
EOF
}

# ─── MAIN ─────────────────────────────────────────────────────

case "${1:-}" in
  --enum-values)
    _print_enum_values
    ;;

  --self)
    claude_pid=$(_find_claude_pid $$) || { echo "ERROR: not inside a claude process tree" >&2; exit 1; }
    uuid=$(_find_session_uuid "$claude_pid") || { echo "ERROR: could not find session UUID for PID $claude_pid" >&2; exit 1; }
    _build_identity "$uuid" "$claude_pid" || exit 1
    ;;

  "")
    claude_pid=$(_find_claude_pid $$) || { echo "ERROR: not inside a claude process tree" >&2; exit 1; }
    uuid=$(_find_session_uuid "$claude_pid") || { echo "ERROR: could not find session UUID for PID $claude_pid" >&2; exit 1; }
    _build_identity "$uuid" "$claude_pid" || exit 1
    ;;

  [0-9a-f]*)
    # UUID provided (can be full UUID or prefix)
    uuid_prefix="$1"
    uuid=""

    # Find full UUID matching this prefix
    for tasks_subdir in "$TASKS_DIR"/*/; do
      dir_uuid=$(basename "$tasks_subdir")
      if [[ "$dir_uuid" == "$uuid_prefix"* ]]; then
        uuid="$dir_uuid"
        break
      fi
    done

    [[ -z "$uuid" ]] && { echo "ERROR: UUID prefix $uuid_prefix not found in $TASKS_DIR" >&2; exit 1; }

    # Find claude PID for this UUID
    found_pid=""
    for pid in $(ps -eo pid | tail -n +2); do
      if _find_session_uuid "$pid" 2>/dev/null | grep -q "^$uuid$"; then
        found_pid=$pid
        break
      fi
    done

    if [[ -z "$found_pid" ]]; then
      echo "ERROR: could not find running claude process with UUID $uuid" >&2
      exit 1
    fi

    _build_identity "$uuid" "$found_pid" || exit 1
    ;;

  *)
    echo "Usage: qhoami [--self | --enum-values | UUID]" >&2
    exit 2
    ;;
esac
