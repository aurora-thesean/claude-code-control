# ---------------------------------------------------------------------------
# gh command execution
# ---------------------------------------------------------------------------

def run_gh(*args, input_text=None):
    """Run a gh command, return (stdout, stderr, returncode)."""
    gh_path = shutil.which('gh')
    if not gh_path:
        return '', 'gh CLI not found. Install from https://cli.github.com and run: gh auth login', 1

    cmd = [gh_path] + list(args)
    log.debug('running: %s', ' '.join(cmd))
    result = subprocess.run(
        cmd,
        capture_output=True,
        text=True,
        input=input_text
    )
    log.debug('exit=%d stdout=%r stderr=%r', result.returncode, result.stdout[:200], result.stderr[:200])
    return result.stdout, result.stderr, result.returncode


def gh_result(stdout, stderr, returncode):
    """Format gh output as MCP tool result content."""
    if returncode != 0:
        return [{"type": "text", "text": f"ERROR (exit {returncode}):\n{stderr.strip() or stdout.strip()}"}]
    return [{"type": "text", "text": stdout.strip() or "(no output)"}]


# ---------------------------------------------------------------------------
# Tool dispatch
# ---------------------------------------------------------------------------

def call_tool(name, args):
    repo = args.get('repo', '')

    if name == 'issue_list':
        cmd = ['issue', 'list', '-R', repo,
               '--state', args.get('state', 'open'),
               '--limit', str(args.get('limit', 20)),
               '--json', 'number,title,state,labels,assignees,createdAt,url']
        if args.get('label'):
            cmd += ['--label', args['label']]
        if args.get('assignee'):
            cmd += ['--assignee', args['assignee']]
        return gh_result(*run_gh(*cmd))

    elif name == 'issue_view':
        return gh_result(*run_gh(
            'issue', 'view', str(args['number']),
            '-R', repo,
            '--json', 'number,title,body,state,labels,assignees,comments,url'
        ))

    elif name == 'issue_create':
        cmd = ['issue', 'create', '-R', repo,
               '--title', args['title']]
        if args.get('body'):
            cmd += ['--body', args['body']]
        for label in args.get('labels', []):
            cmd += ['--label', label]
        for assignee in args.get('assignees', []):
            cmd += ['--assignee', assignee]
        if args.get('milestone'):
            cmd += ['--milestone', args['milestone']]
        return gh_result(*run_gh(*cmd))

    elif name == 'issue_comment':
        return gh_result(*run_gh(
            'issue', 'comment', str(args['number']),
            '-R', repo,
            '--body', args['body']
        ))

    elif name == 'issue_edit':
        cmd = ['issue', 'edit', str(args['number']), '-R', repo]
        if args.get('title'):   cmd += ['--title', args['title']]
        if args.get('body'):    cmd += ['--body', args['body']]
        if args.get('state'):   cmd += ['--state', args['state']]
        for label in args.get('labels', []):
            cmd += ['--add-label', label]
        for assignee in args.get('assignees', []):
            cmd += ['--add-assignee', assignee]
        return gh_result(*run_gh(*cmd))

    elif name == 'pr_list':
        return gh_result(*run_gh(
            'pr', 'list', '-R', repo,
            '--state', args.get('state', 'open'),
            '--limit', str(args.get('limit', 20)),
            '--json', 'number,title,state,headRefName,baseRefName,author,url'
        ))

    elif name == 'pr_create':
        cmd = ['pr', 'create', '-R', repo,
               '--title', args['title'],
               '--head', args['head'],
               '--base', args.get('base', 'main')]
        if args.get('body'):  cmd += ['--body', args['body']]
        if args.get('draft'): cmd += ['--draft']
        for label in args.get('labels', []):
            cmd += ['--label', label]
        for assignee in args.get('assignees', []):
            cmd += ['--assignee', assignee]
        return gh_result(*run_gh(*cmd))

    elif name == 'pr_view':
        return gh_result(*run_gh(
            'pr', 'view', str(args['number']),
            '-R', repo,
            '--json', 'number,title,body,state,headRefName,baseRefName,author,labels,url'
        ))

    elif name == 'pr_merge':
        method_flag = {'merge': '--merge', 'squash': '--squash', 'rebase': '--rebase'}
        cmd = ['pr', 'merge', str(args['number']), '-R', repo,
               method_flag.get(args.get('method', 'merge'), '--merge')]
        if args.get('delete_branch'):
            cmd += ['--delete-branch']
        return gh_result(*run_gh(*cmd))

    elif name == 'label_list':
        return gh_result(*run_gh(
            'label', 'list', '-R', repo,
            '--json', 'name,color,description'
        ))

    elif name == 'label_create':
        cmd = ['label', 'create', args['name'], '-R', repo,
               '--color', args['color']]
        if args.get('description'):
            cmd += ['--description', args['description']]
        return gh_result(*run_gh(*cmd))

    elif name == 'milestone_list':
        return gh_result(*run_gh(
            'api', f'repos/{repo}/milestones',
            '--jq', '[.[] | {number, title, state, due_on, open_issues, closed_issues}]'
        ))

    elif name == 'gh_run':
        return gh_result(*run_gh(*args['args']))

    else:
        return [{"type": "text", "text": f"Unknown tool: {name}"}]


# ---------------------------------------------------------------------------
# MCP stdio protocol (JSON-RPC 2.0, newline-delimited)
# ---------------------------------------------------------------------------

def send(obj):
    line = json.dumps(obj)
    log.debug('send: %s', line[:300])
    sys.stdout.write(line + '\n')
    sys.stdout.flush()


def handle(msg):
    method = msg.get('method', '')
    msg_id = msg.get('id')

    if method == 'initialize':
        send({
            "jsonrpc": "2.0", "id": msg_id,
            "result": {
                "protocolVersion": "2024-11-05",
                "capabilities": {"tools": {}},
                "serverInfo": {"name": "gh-mcp", "version": "1.0.0"}
            }
        })

    elif method == 'initialized':
        pass  # notification, no response

    elif method == 'tools/list':
        send({
            "jsonrpc": "2.0", "id": msg_id,
            "result": {"tools": TOOLS}
        })

    elif method == 'tools/call':
        params = msg.get('params', {})
        tool_name = params.get('name', '')
        tool_args = params.get('arguments', {})
        log.info('tool call: %s %s', tool_name, tool_args)
        content = call_tool(tool_name, tool_args)
        send({
            "jsonrpc": "2.0", "id": msg_id,
            "result": {"content": content, "isError": content[0]["text"].startswith("ERROR")}
        })

    elif method == 'ping':
        send({"jsonrpc": "2.0", "id": msg_id, "result": {}})

    else:
        if msg_id is not None:
            send({
                "jsonrpc": "2.0", "id": msg_id,
                "error": {"code": -32601, "message": f"Method not found: {method}"}
            })


def main():
    log.info('gh-mcp starting')
    for line in sys.stdin:
        line = line.strip()
        if not line:
            continue
        try:
            msg = json.loads(line)
            log.debug('recv: %s', line[:300])
            handle(msg)
        except json.JSONDecodeError as e:
            log.error('bad JSON: %s', e)
        except Exception as e:
            log.exception('unhandled error')


if __name__ == '__main__':
    main()
