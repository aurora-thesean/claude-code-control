#!/usr/bin/env python3
# Phase 10 Unit 2: Warrant Receiver
# HTTP server for receiving warrant POST requests from remote agents
#
# Usage:
#   qlaude-warrant-receiver [--port 9231] [--host 127.0.0.1] [--daemon]

import http.server
import socketserver
import json
import os
import sys
import argparse
import logging
from datetime import datetime, timezone, timedelta
from pathlib import Path
import base64
from cryptography.hazmat.primitives import hashes, serialization
from cryptography.hazmat.primitives.asymmetric import padding
from cryptography.hazmat.backends import default_backend

# Setup logging
logging.basicConfig(
    level=logging.INFO,
    format='[qlaude-warrant-receiver] %(message)s',
    stream=sys.stderr
)
logger = logging.getLogger(__name__)

# Configuration
WARRANT_DIR = Path.home() / '.aurora-agent' / 'warrants'
AUDIT_LOG = Path.home() / '.aurora-agent' / '.qlaude-audit.jsonl'

# Ensure directories exist
WARRANT_DIR.mkdir(parents=True, exist_ok=True)
AUDIT_LOG.parent.mkdir(parents=True, exist_ok=True)


def verify_warrant_signature(warrant_data):
    """
    Verify RSA-SHA256 signature on warrant.
    Returns: (is_valid, error_message)
    """
    try:
        # Check for signature
        if 'signature' not in warrant_data:
            return False, 'No signature in warrant'

        # Check algorithm
        algo = warrant_data.get('signature_algorithm', 'unknown')
        if algo != 'RSA-SHA256':
            return False, f'Unsupported signature algorithm: {algo}'

        # Check expiration
        expires_at_str = warrant_data.get('expires_at')
        if expires_at_str:
            try:
                expires_at = datetime.fromisoformat(expires_at_str)
                if datetime.now(timezone.utc) > expires_at:
                    return False, f'Warrant expired at {expires_at_str}'
            except Exception as e:
                return False, f'Invalid expiration timestamp: {e}'

        # Load parent's public key
        parent_uuid = warrant_data.get('parent_uuid', 'unknown')
        parent_pubkey_path = WARRANT_DIR.parent / f'parent-{parent_uuid}.pem'

        # Fallback: try generic parent-public-key.pem
        if not parent_pubkey_path.exists():
            parent_pubkey_path = WARRANT_DIR.parent / 'parent-public-key.pem'

        if not parent_pubkey_path.exists():
            return False, f'Parent public key not found (tried {parent_pubkey_path})'

        # Load public key
        try:
            with open(parent_pubkey_path, 'rb') as f:
                public_key = serialization.load_pem_public_key(
                    f.read(),
                    backend=default_backend()
                )
        except Exception as e:
            return False, f'Failed to load public key: {e}'

        # Extract and decode signature
        try:
            signature_b64 = warrant_data.get('signature')
            signature = base64.b64decode(signature_b64)
        except Exception as e:
            return False, f'Invalid base64 signature: {e}'

        # Create canonical JSON for verification
        canonical_json = json.dumps(
            {k: warrant_data[k] for k in sorted(warrant_data.keys())
             if k not in ['signature', 'signature_algorithm']},
            separators=(',', ':'),
            sort_keys=True
        )

        # Verify signature
        try:
            public_key.verify(
                signature,
                canonical_json.encode('utf-8'),
                padding.PSS(
                    mgf=padding.MGF1(hashes.SHA256()),
                    salt_length=padding.PSS.MAX_LENGTH
                ),
                hashes.SHA256()
            )
            return True, 'Signature valid'
        except Exception as e:
            return False, f'Signature verification failed: {e}'

    except Exception as e:
        return False, f'Verification error: {e}'


class WarrantHandler(http.server.BaseHTTPRequestHandler):
    """HTTP request handler for warrant reception"""
    
    def log_message(self, format, *args):
        """Override to use our logger"""
        logger.info(format % args)
    
    def do_POST(self):
        """Handle POST requests for warrant submission"""
        
        if self.path != '/warrant':
            self.send_error(404, 'Endpoint not found')
            return
        
        try:
            # Read content length
            content_length = int(self.headers.get('Content-Length', 0))
            if content_length == 0:
                self.send_error(400, 'Missing Content-Length')
                return
            
            # Read warranty JSON
            body = self.rfile.read(content_length).decode('utf-8')
            
            # Validate JSON
            try:
                warrant_data = json.loads(body)
            except json.JSONDecodeError as e:
                self.send_response(400)
                self.send_header('Content-Type', 'application/json')
                self.end_headers()
                self.wfile.write(json.dumps({'error': 'Invalid JSON'}).encode())
                return
            
            # Extract warranty_id
            warrant_id = warrant_data.get('warrant_id')
            if not warrant_id:
                self.send_response(400)
                self.send_header('Content-Type', 'application/json')
                self.end_headers()
                self.wfile.write(json.dumps({'error': 'Missing warrant_id'}).encode())
                return

            # PHASE 10b.1: Verify signature (optional, but recommended)
            # If signature is present, verify it
            if 'signature' in warrant_data:
                is_valid, error_msg = verify_warrant_signature(warrant_data)
                if not is_valid:
                    self.send_response(401)
                    self.send_header('Content-Type', 'application/json')
                    self.end_headers()
                    self.wfile.write(json.dumps({'error': f'Signature verification failed: {error_msg}'}).encode())
                    logger.warning(f'Warrant {warrant_id} rejected: {error_msg}')
                    return
                logger.info(f'Warrant {warrant_id} signature verified')
            else:
                logger.warning(f'Warrant {warrant_id} has no signature (Phase 10a compatibility)')

            # Check if warranty already exists
            warrant_file = WARRANT_DIR / f'{warrant_id}.json'
            if warrant_file.exists():
                self.send_response(409)
                self.send_header('Content-Type', 'application/json')
                self.end_headers()
                self.wfile.write(json.dumps({'error': f'Warranty {warrant_id} already exists'}).encode())
                return
            
            # Write warranty to file
            try:
                with open(warrant_file, 'w') as f:
                    json.dump(warrant_data, f, indent=2)
            except IOError as e:
                self.send_response(500)
                self.send_header('Content-Type', 'application/json')
                self.end_headers()
                self.wfile.write(json.dumps({'error': 'Failed to write warranty file'}).encode())
                return
            
            logger.info(f'Received warranty: {warrant_id}')
            
            # Log to audit trail
            audit_entry = {
                'timestamp': datetime.now(timezone.utc).isoformat().replace('+00:00', 'Z'),
                'action': 'warrant-received',
                'target': warrant_id,
                'decision': 'RECEIVED',
                'qc_level': '2',
                'loa_cap': 2,
                'reason': 'Received from network',
                'signature_verified': 'signature' in warrant_data
            }
            
            with open(AUDIT_LOG, 'a') as f:
                f.write(json.dumps(audit_entry) + '\n')
            
            # Return success response
            self.send_response(201)
            self.send_header('Content-Type', 'application/json')
            response = {
                'status': 'RECEIVED',
                'warrant_id': warrant_id,
                'local_path': str(warrant_file)
            }
            response_json = json.dumps(response).encode()
            self.send_header('Content-Length', len(response_json))
            self.end_headers()
            self.wfile.write(response_json)
            
        except Exception as e:
            logger.error(f'Error handling POST: {e}')
            self.send_error(500, 'Internal server error')
    
    def do_GET(self):
        """Handle GET requests for health check"""
        if self.path == '/health':
            self.send_response(200)
            self.send_header('Content-Type', 'application/json')
            self.end_headers()
            self.wfile.write(json.dumps({'status': 'ok'}).encode())
        else:
            self.send_error(404, 'Not found')


def main():
    parser = argparse.ArgumentParser(description='Warrant Receiver Server')
    parser.add_argument('--port', type=int, default=9231, help='Port to listen on (default: 9231)')
    parser.add_argument('--host', default='127.0.0.1', help='Host to bind to (default: 127.0.0.1)')
    parser.add_argument('--daemon', action='store_true', help='Run as daemon')
    
    args = parser.parse_args()
    
    # Validate port
    if args.port < 1024 or args.port > 65535:
        logger.error(f'Invalid port: {args.port} (must be 1024-65535)')
        sys.exit(1)
    
    logger.info(f'Starting warrant receiver on {args.host}:{args.port}')
    
    try:
        with socketserver.TCPServer((args.host, args.port), WarrantHandler) as httpd:
            logger.info(f'Server listening on {args.host}:{args.port}')
            httpd.serve_forever()
    except OSError as e:
        logger.error(f'Failed to start server: {e}')
        sys.exit(1)
    except KeyboardInterrupt:
        logger.info('Server stopped')
        sys.exit(0)


if __name__ == '__main__':
    main()
